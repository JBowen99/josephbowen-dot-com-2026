---
import Layout from '../layouts/Layout.astro';
import { getOgImage } from '../lib/og-image';

const softwareExperience = [
	{
		role: 'Full Stack Software Engineer',
		company: 'Silver Stag Studios',
		period: 'Mar 2024 – Present',
		highlights: [
			'Design and build full-stack web and mobile applications for operational and customer-facing business problems.',
			'Own features from technical design through deployment using React, TypeScript, Node.js, and SQL databases.',
			'Deploy and maintain applications on Netlify, Vercel, and self-hosted environments.',
		],
	},
	{
		role: 'Software Engineer',
		company: 'Dimension Studios',
		period: 'Jun – Aug 2025',
		highlights: [
			'Modernized an AI-powered onboarding platform using React and TypeScript.',
			'Improved UX and communication flows for customer-facing sales and onboarding systems.',
			'Integrated AI SDK functionality into production application workflows.',
		],
	},
];

const engineeringExperience = [
	{
		role: 'Design & Manufacturing Engineer',
		company: 'Beeline Wheelchairs',
		period: 'Mar 2024 – Present',
		highlights: [
			'Designed wheelchair components and assemblies in CAD from concept through production.',
			'Implemented inventory and ERP processes to improve operational efficiency.',
			'Established manufacturing workflows, documentation, and training for fiber laser production.',
		],
	},
	{
		role: 'Senior Test Engineer',
		company: 'DEKA Research',
		period: 'Sep 2021 – Feb 2024',
		highlights: [
			'Designed and executed V&V test protocols for medical devices in regulated environments.',
			'Authored technical documentation aligned with ISO, ANSI, and BS EN standards.',
			'Built Python automation tools and supported 510(k) submission activities.',
		],
	},
];

const experienceGroups = [
	{ title: 'Software', jobs: softwareExperience },
	{ title: 'Engineering', jobs: engineeringExperience },
];

const projects = [
	{
		name: 'Wrkin.space',
		url: 'https://wrkin.space',
		description: 'Workspace and productivity platform for modern teams.',
	},
	{
		name: 'Cookify AI',
		url: 'https://cookifyai.com',
		description: 'AI-powered recipe and meal planning application.',
	},
	{
		name: 'Pretty Screenshot',
		url: 'https://prettyscreenshot.com',
		description: 'Tool for creating polished, shareable screenshots.',
	},
	{
		name: 'Chess Stat Tracker',
		url: 'https://chessstattracker.josephbowen.com',
		description: 'Analytics dashboard for tracking chess performance.',
	},
] satisfies Array<{
	name: string;
	url: string;
	description: string;
	image?: string;
}>;

const projectsWithImages = await Promise.all(
	projects.map(async (project) => ({
		...project,
		image: project.image ?? (await getOgImage(project.url)),
	})),
);

const skills = {
	Software: [
		'TypeScript',
		'JavaScript',
		'React',
		'React Native',
		'Next.js',
		'Svelte',
		'Python',
		'Node.js',
		'SQL',
		'PostgreSQL',
		'Supabase',
	],
	'Tools & Platforms': ['Git', 'REST APIs', 'AI Integration', 'Netlify', 'Vercel'],
	'DevOps & Hosting': [
		'Coolify',
		'Docker',
		'Linux',
		'CI/CD',
		'Server Administration',
		'Self-hosting',
	],
	Engineering: [
		'SolidWorks',
		'CAD',
		'Design for Manufacturing',
		'ISO Standards',
		'Medical Device Compliance',
		'510(k)',
	],
};

---

<Layout>
	<div class="page">
		<aside class="sidebar">
			<header class="hero">
				<p class="eyebrow">Portfolio</p>
				<h1>Joseph Bowen</h1>
				<p class="tagline">Product Engineer · Full-Stack Software · Biomedical Engineer</p>
			</header>

			<p class="intro">
				Product Engineer with experience designing software and operational tools across
				healthcare, engineering, and startup environments. Background spans regulated medical
				device development, AI-powered web applications, workflow automation, and cross-functional
				product delivery.
			</p>

			<div class="social-links">
				<a
					class="social-link"
					href="https://linkedin.com/in/joseph-bowen"
					target="_blank"
					rel="noopener noreferrer"
					aria-label="LinkedIn"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
						<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
					</svg>
				</a>
				<a
					class="social-link"
					href="https://github.com/JBowen99"
					target="_blank"
					rel="noopener noreferrer"
					aria-label="GitHub"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
						<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
					</svg>
				</a>
			</div>

			<div class="sidebar-meta">
				<section>
					<h2>Skills</h2>
					<div class="skills">
						{
							Object.entries(skills).map(([category, items]) => (
								<div class="skill-group">
									<h3>{category}</h3>
									<ul class="skill-tags">
										{items.map((item) => (
											<li>{item}</li>
										))}
									</ul>
								</div>
							))
						}
					</div>
				</section>

				<section>
					<h2>Education</h2>
					<div class="education">
						<p class="degree">Bachelor of Science in Engineering — Biomedical Concentration</p>
						<p class="school">LeTourneau University · 2017 – 2021</p>
					</div>
				</section>
			</div>

			<footer>
				<p>© {new Date().getFullYear()}</p>
			</footer>
		</aside>

		<main class="content">
			<section id="experience">
				<h2>Experience</h2>
				{
					experienceGroups.map((group) => (
						<div class="experience-group">
							<h3>{group.title}</h3>
							<ul class="timeline">
								{group.jobs.map((job) => (
									<li>
										<div class="job-header">
											<div class="job-title">
												<span class="role">{job.role}</span>
												<span class="company">{job.company}</span>
											</div>
											<span class="period">{job.period}</span>
										</div>
										<ul class="highlights">
											{job.highlights.map((item) => (
												<li>{item}</li>
											))}
										</ul>
									</li>
								))}
							</ul>
						</div>
					))
				}
			</section>

			<section id="projects">
				<h2>Personal Projects</h2>
				<p class="section-note">Side projects I've built independently — not client or employer work.</p>
				<ul class="projects">
					{
						projectsWithImages.map((project) => (
							<li class="project-item">
								<a href={project.url} target="_blank" rel="noopener noreferrer">
									<span class="project-name">{project.name}</span>
									<span class="arrow" aria-hidden="true">↗</span>
								</a>
								<div class="project-preview" aria-hidden="true">
									{
										project.image ? (
											<img
												class="project-preview-image"
												src={project.image}
												alt=""
												width="480"
												height="252"
												loading="lazy"
												decoding="async"
											/>
										) : null
									}
									<div class="project-preview-body">
										<p class="project-preview-desc">{project.description}</p>
										<p class="project-preview-url">
											{new URL(project.url).hostname.replace(/^www\./, '')}
										</p>
									</div>
								</div>
							</li>
						))
					}
				</ul>
			</section>
		</main>
	</div>
</Layout>

<script>
	const items = document.querySelectorAll<HTMLElement>('.project-item');

	if (window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
		for (const item of items) {
			const preview = item.querySelector<HTMLElement>('.project-preview');
			if (!preview) continue;

			const showPreview = () => {
				const rect = item.getBoundingClientRect();
				const previewHeight = preview.offsetHeight || 220;
				const centerX = rect.left + rect.width / 2;
				const showBelow = rect.top - previewHeight - 16 < 12;

				preview.classList.remove('is-visible');
				preview.style.left = `${centerX}px`;
				preview.style.top = showBelow ? `${rect.bottom + 10}px` : `${rect.top - 10}px`;
				preview.dataset.placement = showBelow ? 'below' : 'above';

				// Apply position before fading in so the card doesn't animate from 0,0
				void preview.offsetWidth;
				requestAnimationFrame(() => preview.classList.add('is-visible'));
			};

			const hidePreview = () => preview.classList.remove('is-visible');

			item.addEventListener('mouseenter', showPreview);
			item.addEventListener('mouseleave', hidePreview);
			item.addEventListener('focusin', showPreview);
			item.addEventListener('focusout', (event) => {
				if (!item.contains(event.relatedTarget as Node)) hidePreview();
			});
		}
	}
</script>
